              "curator-role",
              "concepts"
            ]
          },
          {
            "group": "Getting Started",
            "pages": [
              "prerequisites",
              "authentication",
              "permissions",
              "quickstart"
            ]
          },
          {
            "group": "UI Guide",
            "pages": [
              "ui/home",
              "ui/dashboard",
              "ui/strategy",
              "ui/ladder",
              "ui/merkle-trees",
              "ui/yield-sources",
              "ui/user-management",
              "ui/vault-settings",
              "ui/history",
              "ui/services",
              "ui/pause",
              "ui/registry",
              "ui/admin",
              "ui/create-vault",
              "ui/alerts"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Reference",
            "pages": [
              "api/overview",
              "api/erebor",
              "api/superman",
              "api/strategy",
              "api/oms"
            ]
          }
        ]
      },
      {
        "tab": "Automation",
        "groups": [
          {
            "group": "Automation Guide",
            "pages": [
              "automation/overview",
              "automation/monitoring",
              "automation/ladders",
              "automation/services",
              "automation/webhooks"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API Reference",
          "href": "api/overview",
          "icon": "code"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/superform-xyz",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "superform.xyz",
        "href": "https://superform.xyz"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Launch App",
      "href": "https://superman.superform.xyz"
    }
  },
  "footer": {
    "socials": {
      "x": "https://twitter.com/superform",
      "github": "https://github.com/superform-xyz"
    }
