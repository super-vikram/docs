{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SuperVaults Curator Docs",
  "colors": {
    "primary": "#6B46C1",
    "light": "#9F7AEA",
    "dark": "#553C9A"
  },
  "favicon": "/favicon.svg",
  "navigation": {
